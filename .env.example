# Discord application / bot settings
DISCORD_CLIENT_ID=your_discord_application_client_id
DISCORD_CLIENT_SECRET=your_discord_application_client_secret
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_server_guild_id

# Public URL that Discord redirects back to. For local testing with a tunnel:
# PUBLIC_URL=https://your-tunnel.example.com
PUBLIC_URL=http://localhost:3000
PORT=3000

# Generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_a_long_random_secret

# Optional: where JSON persistence is stored
DATA_FILE=./data/store.json
